// must be flagged for native review before shipping, same rule applied
// here. These tables are intentionally NOT wired to any UI yet — there is
// no language switcher in this file to drive them. If/when the real i18n
// system above is merged into this file, prefer wiring these 17 keys into
// ITS string tables/loadLanguage() rather than building a second,
// competing switcher here.
const SR_STRINGS_HI={
